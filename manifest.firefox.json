{
  "manifest_version": 2,
  "name": "Nafer Shield",
  "short_name": "Nafer",
  "version": "1.0.0",
  "description": "Lightweight & beautiful ad blocker. Block ads, trackers, and malware.",
  "author": "Nafer Platform",

  "icons": {
    "16":  "assets/icons/icon-16.png",
    "32":  "assets/icons/icon-32.png",
    "48":  "assets/icons/icon-48.png",
    "128": "assets/icons/icon-128.png"
  },

  "browser_action": {
    "default_popup": "ui/popup/index.html",
    "default_icon": {
      "16":  "assets/icons/icon-16.png",
      "32":  "assets/icons/icon-32.png",
      "48":  "assets/icons/icon-48.png",
      "128": "assets/icons/icon-128.png"
    },
    "default_title": "Nafer Shield"
  },

  "background": {
    "scripts": ["dist/background.js"],
    "persistent": false
  },

  "content_scripts": [
    {
      "matches": ["http://*/*", "https://*/*"],
      "js": ["dist/content.js"],
      "run_at": "document_start",
      "all_frames": true
    }
  ],

  "permissions": [
    "storage",
    "tabs",
    "webRequest",
    "webRequestBlocking",
    "alarms",
    "<all_urls>"
  ],

  "options_ui": {
    "page": "ui/settings/index.html",
    "open_in_tab": true
  },

  "browser_specific_settings": {
    "gecko": {
      "id": "nafer-shield@nafer.io",
      "strict_min_version": "109.0"
    }
  },

  "web_accessible_resources": ["assets/web/*"]
}
